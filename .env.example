# =============================================================================
# Decision OS — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
# All variables are optional — the app works in local-only mode without them.
# =============================================================================

# ── Supabase (Auth + Cloud Sync) ────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase Auth Providers (configure in Supabase Dashboard) ───────────────
# GitHub: Settings → Authentication → Providers → GitHub
#   - Create a GitHub OAuth App: https://github.com/settings/developers
#   - Set the callback URL to: https://<your-supabase-project>.supabase.co/auth/v1/callback
#
# Google: Settings → Authentication → Providers → Google
#   - Create credentials: https://console.cloud.google.com/apis/credentials
#   - Set the redirect URI to: https://<your-supabase-project>.supabase.co/auth/v1/callback

# ── Sentry (Error Monitoring) ──────────────────────────────────────────────
# Get your DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Required only for source-map upload in CI builds:
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
